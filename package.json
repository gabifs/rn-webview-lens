{
  "name": "rn-webview-lens",
  "displayName": "React Native WebView Lens",
  "description": "JavaScript syntax highlighting for react-native-webview injectedJavaScript props",
  "version": "0.1.0",
  "publisher": "gabifs",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabifs/rn-webview-lens.git"
  },
  "homepage": "https://github.com/gabifs/rn-webview-lens#readme",
  "bugs": {
    "url": "https://github.com/gabifs/rn-webview-lens/issues"
  },
  "galleryBanner": {
    "color": "#282c34",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "react-native",
    "webview",
    "syntax-highlighting",
    "injectedJavaScript",
    "react-native-webview"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "inline-js.injection.rn-webview-lens",
        "path": "./syntaxes/injection.json",
        "injectTo": [
          "source.js",
          "source.jsx",
          "source.ts",
          "source.tsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript"
        },
        "tokenTypes": {
          "meta.embedded.block.javascript": "other"
        }
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:typescript --format=cjs --platform=node --minify --tree-shaking=true",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:typescript --format=cjs --platform=node --watch",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
